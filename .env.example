# --- Configurações de Banco de Dados ---
# URL de conexão com o banco de dados. 
# Exemplos:
# SQLite: "sqlite:///./sql_app.db"
# PostgreSQL: "postgresql://usuario:senha@localhost/nome_do_banco"
DATABASE_URL=""

# --- Segurança e Autenticação ---
# Chave mestra para assinar os tokens JWT. 
# Em produção, use uma string aleatória longa (ex: gerada por '>>> import secrets >>> secrets.token_hex(32)')
SECRET_KEY="minha-chave-secreta-super-segura"

# Algoritmo de criptografia utilizado para o token JWT (padrão: HS256)
ALGORITHM="HS256"

# Tempo de vida do token de acesso em minutos antes de expirar
ACCESS_TOKEN_EXPIRE_MINUTES=30